page {
    font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', 'Segoe UI', Roboto, sans-serif;
    font-size: 28rpx;
    color: #1F2937;
    background-color: #F5F7FA;
    line-height: 1.6;
    letter-spacing: 0.3rpx;
}

.container {
    padding: 28rpx 24rpx 48rpx;
    box-sizing: border-box;
    min-height: 100vh;
}

.card {
    background: #ffffff;
    border-radius: 24rpx;
    padding: 28rpx 32rpx;
    margin-bottom: 20rpx;
    box-shadow: 0 2rpx 16rpx rgba(15, 23, 42, 0.04),
                0 1rpx 4rpx rgba(15, 23, 42, 0.02);
}

.card-xl {
    background: #ffffff;
    border-radius: 32rpx;
    padding: 36rpx;
    margin-bottom: 24rpx;
    box-shadow: 0 4rpx 24rpx rgba(15, 23, 42, 0.06);
}

.btn-primary {
    background: linear-gradient(135deg, #4CAF50 0%, #66BB6A 100%);
    color: #ffffff;
    border-radius: 50rpx;
    font-size: 30rpx;
    padding: 24rpx 0;
    font-weight: 600;
    letter-spacing: 2rpx;
    border: none;
    box-shadow: 0 6rpx 20rpx rgba(76, 175, 80, 0.25);
    line-height: 1.4;
}
.btn-primary::after { border: none; }
.btn-primary:active {
    background: linear-gradient(135deg, #388E3C, #4CAF50);
    transform: translateY(2rpx);
    box-shadow: 0 2rpx 8rpx rgba(76, 175, 80, 0.2);
}

.btn-outline {
    background: #ffffff;
    color: #4CAF50;
    border: 2rpx solid #4CAF50;
    border-radius: 50rpx;
    font-size: 30rpx;
    padding: 22rpx 0;
    font-weight: 500;
}
.btn-outline::after { border: none; }
.btn-outline:active { background: #E8F5E9; }

.btn-small {
    background: #E8F5E9;
    color: #2E7D32;
    border-radius: 30rpx;
    font-size: 24rpx;
    padding: 12rpx 28rpx;
    line-height: 1.4;
    display: inline-block;
    border: none;
    font-weight: 500;
}
.btn-small::after { border: none; }

.section-title {
    font-size: 32rpx;
    font-weight: 700;
    color: #1F2937;
    margin: 8rpx 4rpx 20rpx;
    display: flex;
    align-items: center;
}
.section-title::before {
    content: '';
    display: inline-block;
    width: 6rpx;
    height: 28rpx;
    border-radius: 4rpx;
    background: linear-gradient(180deg, #4CAF50, #66BB6A);
    margin-right: 16rpx;
    flex-shrink: 0;
}

.flex-row { display: flex; flex-direction: row; align-items: center; }
.flex-column { display: flex; flex-direction: column; }
.flex-between { display: flex; justify-content: space-between; align-items: center; }
.flex-center { display: flex; justify-content: center; align-items: center; }
.flex-1 { flex: 1; }

.text-center { text-align: center; }
.text-right { text-align: right; }
.text-gray { color: #8B95A7; }
.text-gray-dark { color: #6B7280; }
.text-green { color: #4CAF50; }
.text-red { color: #EF4444; }
.text-orange { color: #F97316; }
.text-blue { color: #3B82F6; }
.text-purple { color: #8B5CF6; }
.text-dark { color: #1F2937; }
.text-white { color: #ffffff; }

.text-sm { font-size: 24rpx; }
.text-xs { font-size: 22rpx; }
.text-lg { font-size: 36rpx; }
.text-xl { font-size: 42rpx; }
.text-bold { font-weight: 700; }
.text-semibold { font-weight: 600; }
.text-medium { font-weight: 500; }

.mt-8 { margin-top: 8rpx; }
.mt-16 { margin-top: 16rpx; }
.mt-20 { margin-top: 20rpx; }
.mt-24 { margin-top: 24rpx; }
.mt-32 { margin-top: 32rpx; }
.mb-8 { margin-bottom: 8rpx; }
.mb-16 { margin-bottom: 16rpx; }
.mb-20 { margin-bottom: 20rpx; }
.mb-24 { margin-bottom: 24rpx; }

.tag {
    display: inline-block;
    background: #F1F5F9;
    color: #475569;
    padding: 8rpx 20rpx;
    border-radius: 30rpx;
    font-size: 24rpx;
    font-weight: 500;
    line-height: 1.4;
    margin-right: 10rpx;
    margin-bottom: 8rpx;
}
.tag-green { background: #E8F5E9; color: #2E7D32; }
.tag-blue { background: #E3F2FD; color: #1E88E5; }
.tag-orange { background: #FFF3E0; color: #EF6C00; }
.tag-red { background: #FFEBEE; color: #C62828; }
.tag-purple { background: #F3E5F5; color: #6A1B9A; }

.empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 100rpx 40rpx;
    background: #ffffff;
    border-radius: 24rpx;
    box-shadow: 0 2rpx 16rpx rgba(15, 23, 42, 0.04);
}
.empty-state-icon { font-size: 120rpx; margin-bottom: 24rpx; opacity: 0.7; }
.empty-state-title { font-size: 30rpx; color: #374151; margin-bottom: 12rpx; font-weight: 500; }
.empty-state-desc { font-size: 24rpx; color: #9CA3AF; }

.modal {
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
    background: rgba(15, 23, 42, 0.5);
    display: flex;
    align-items: flex-end;
    z-index: 999;
    animation: fadeIn 0.2s ease;
}
@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
@keyframes slideUp { from { transform: translateY(100%); } to { transform: translateY(0); } }

.modal-content {
    background: #fff;
    width: 100%;
    border-radius: 32rpx 32rpx 0 0;
    padding: 36rpx 32rpx calc(36rpx + env(safe-area-inset-bottom));
    max-height: 85vh;
    overflow-y: auto;
    box-sizing: border-box;
    animation: slideUp 0.3s cubic-bezier(0.16, 1, 0.3, 1);
}
.modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 32rpx;
}
.modal-title {
    font-size: 34rpx;
    font-weight: 700;
    color: #1F2937;
}
.modal-close {
    font-size: 36rpx;
    color: #9CA3AF;
    padding: 8rpx 16rpx;
}

.form-field {
    margin-bottom: 24rpx;
}
.form-label {
    display: block;
    font-size: 26rpx;
    color: #475569;
    font-weight: 500;
    margin-bottom: 12rpx;
}
.form-input {
    width: 100%;
    box-sizing: border-box;
    height: 88rpx;
    background: #F8FAFC;
    border: 2rpx solid #E2E8F0;
    border-radius: 16rpx;
    padding: 0 24rpx;
    font-size: 28rpx;
    color: #1F2937;
}
.form-input:focus { border-color: #4CAF50; background: #ffffff; }
.picker-box {
    height: 88rpx;
    background: #F8FAFC;
    border: 2rpx solid #E2E8F0;
    border-radius: 16rpx;
    padding: 0 24rpx;
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 28rpx;
    color: #1F2937;
}
.picker-arrow { color: #9CA3AF; }

.btn-modal {
    width: 100%;
    margin-top: 16rpx;
    padding: 24rpx 0;
}