<view class="mine-container">

    <view class="profile-card">
        <view class="profile-bg"></view>
        <view class="profile-bg-circle profile-bg-circle-1"></view>
        <view class="profile-bg-circle profile-bg-circle-2"></view>

        <view class="profile-inner">
            <view class="profile-avatar-wrap">
                <view class="profile-avatar">{{avatarChar}}</view>
            </view>
            <view class="profile-info">
                <view class="profile-name">{{displayName}}</view>
                <view class="profile-desc" wx:if="{{userInfo.email}}">{{userInfo.email}}</view>
                <view class="profile-tags">
                    <text class="tag tag-green" style="margin-right:8rpx;">健康管理</text>
                </view>
            </view>
            <view class="profile-edit" bindtap="goToProfileEdit">
                <text>编辑 ›</text>
            </view>
        </view>

        <view class="stats-row">
            <view class="stats-cell">
                <view class="stats-num">{{stats.records || 0}}</view>
                <view class="stats-label">记录数</view>
            </view>
            <view class="stats-divider"></view>
            <view class="stats-cell">
                <view class="stats-num">{{stats.days || 0}}</view>
                <view class="stats-label">坚持天数</view>
            </view>
            <view class="stats-divider"></view>
            <view class="stats-cell">
                <view class="stats-num">{{stats.plans || 0}}</view>
                <view class="stats-label">健康计划</view>
            </view>
        </view>
    </view>

    <view class="section-title">功能入口</view>
    <view class="card menu-card">
        <view class="menu-item" bindtap="goToBodyData">
            <view class="menu-icon menu-icon-green">📊</view>
            <view class="menu-text">
                <view class="menu-title">体征记录</view>
                <view class="menu-subtitle">查看和记录身体指标</view>
            </view>
            <view class="menu-arrow">›</view>
        </view>
        <view class="menu-item" bindtap="goToDiet">
            <view class="menu-icon menu-icon-orange">🍽️</view>
            <view class="menu-text">
                <view class="menu-title">饮食记录</view>
                <view class="menu-subtitle">科学饮食，健康一生</view>
            </view>
            <view class="menu-arrow">›</view>
        </view>
        <view class="menu-item" bindtap="goToSport">
            <view class="menu-icon menu-icon-blue">🏃</view>
            <view class="menu-text">
                <view class="menu-title">运动记录</view>
                <view class="menu-subtitle">挥洒汗水，焕发活力</view>
            </view>
            <view class="menu-arrow">›</view>
        </view>
        <view class="menu-item" bindtap="goToHealthPlan">
            <view class="menu-icon menu-icon-purple">📋</view>
            <view class="menu-text">
                <view class="menu-title">健康计划</view>
                <view class="menu-subtitle">制定专属健康方案</view>
            </view>
            <view class="menu-arrow">›</view>
        </view>
    </view>

    <view class="section-title">其他</view>
    <view class="card menu-card">
        <view class="menu-item" bindtap="clearCache">
            <view class="menu-icon menu-icon-gray">🧹</view>
            <view class="menu-text">
                <view class="menu-title">清除缓存</view>
                <view class="menu-subtitle">清理小程序缓存数据</view>
            </view>
            <view class="menu-arrow">›</view>
        </view>
        <view class="menu-item" bindtap="onAbout">
            <view class="menu-icon menu-icon-gray">ℹ️</view>
            <view class="menu-text">
                <view class="menu-title">关于我们</view>
                <view class="menu-subtitle">了解健康管理系统</view>
            </view>
            <view class="menu-arrow">›</view>
        </view>
    </view>

    <button class="btn-logout" bindtap="logout">退出登录</button>

</view>