<!-- pages/diet/diet.wxml -->
<view class="container">

    <!-- 顶部操作栏 -->
    <view class="action-bar">
        <view class="action-title">
            <text class="action-title-text">饮食记录</text>
            <text class="action-title-sub">共 {{records.length}} 条记录</text>
        </view>
        <button class="btn-add" bindtap="showAddForm">+ 记录</button>
    </view>

    <!-- 记录列表 -->
    <view wx:for="{{records}}" wx:key="id" class="record-item">
        <view class="record-item-header">
            <view style="display:flex;align-items:center;flex:1;">
                <text class="record-item-title">{{item.food_name}}</text>
                <text class="record-item-badge">{{item.meal_type_display}}</text>
            </view>
            <text class="record-item-delete" data-id="{{item.id}}" bindtap="deleteRecord">删除</text>
        </view>
        <view class="record-item-data">
            <text class="data-tag" wx:if="{{item.portion_size}}">分量<strong>{{item.portion_size}}</strong></text>
            <text class="data-tag data-tag-green" wx:if="{{item.calories}}">热量<strong>{{item.calories}} 千卡</strong></text>
            <text class="data-tag" wx:if="{{item.protein}}">蛋白质<strong>{{item.protein}}g</strong></text>
            <text class="data-tag" wx:if="{{item.fat}}">脂肪<strong>{{item.fat}}g</strong></text>
            <text class="data-tag" wx:if="{{item.carbohydrate}}">碳水<strong>{{item.carbohydrate}}g</strong></text>
        </view>
        <view class="record-item-footer">📅 {{item.record_datetime}}</view>
    </view>

    <view wx:if="{{records.length === 0}}" class="empty-state">
        <view class="empty-icon">🍽️</view>
        <view class="empty-title">暂无饮食记录</view>
        <view class="empty-desc">记录你的每一餐，守护健康生活</view>
    </view>

    <!-- 弹窗 -->
    <view class="modal" wx:if="{{showForm}}" catchtap="hideForm">
        <view class="modal-content" catchtap="">
            <view class="modal-header">
                <view class="modal-title">记录饮食</view>
                <text class="modal-close" bindtap="hideForm">✕</text>
            </view>

            <view class="modal-form">
                <view class="form-field">
                    <text class="form-label">🍴 餐别</text>
                    <view class="type-selector">
                        <text class="type-tag {{form.meal_type === item.value ? 'type-tag-active' : ''}}"
                              wx:for="{{mealTypes}}" wx:key="value"
                              data-type="{{item.value}}" bindtap="selectMealType">{{item.label}}</text>
                    </view>
                </view>
                <view class="form-field">
                    <text class="form-label">🍱 食物名称</text>
                    <input placeholder="例如：米饭、鸡胸肉、蔬菜沙拉..." value="{{form.food_name}}" data-field="food_name" bindinput="onFormInput" class="form-input"/>
                </view>
                <view class="form-field">
                    <text class="form-label">🥄 分量</text>
                    <input placeholder="例如：1碗、200g、1份" value="{{form.portion_size}}" data-field="portion_size" bindinput="onFormInput" class="form-input"/>
                </view>
                <view class="form-field">
                    <text class="form-label">🔥 热量(千卡)</text>
                    <input type="number" placeholder="约多少千卡" value="{{form.calories}}" data-field="calories" bindinput="onFormInput" class="form-input"/>
                </view>
                <view class="form-field">
                    <text class="form-label">🥩 蛋白质(g)</text>
                    <input type="digit" placeholder="约多少克" value="{{form.protein}}" data-field="protein" bindinput="onFormInput" class="form-input"/>
                </view>
                <view class="form-field">
                    <text class="form-label">🥑 脂肪(g)</text>
                    <input type="digit" placeholder="约多少克" value="{{form.fat}}" data-field="fat" bindinput="onFormInput" class="form-input"/>
                </view>
                <view class="form-field">
                    <text class="form-label">🍚 碳水(g)</text>
                    <input type="digit" placeholder="约多少克" value="{{form.carbohydrate}}" data-field="carbohydrate" bindinput="onFormInput" class="form-input"/>
                </view>
                <view class="form-field">
                    <text class="form-label">💭 备注</text>
                    <input placeholder="选填，记录用餐感受..." value="{{form.remark}}" data-field="remark" bindinput="onFormInput" class="form-input"/>
                </view>
            </view>

            <button class="btn-primary btn-modal" bindtap="saveRecord">保 存</button>
        </view>
    </view>
</view>