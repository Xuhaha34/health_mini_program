.hero-card {
    position: relative;
    overflow: hidden;
    background: linear-gradient(135deg, #4CAF50 0%, #66BB6A 50%, #81C784 100%);
    border-radius: 32rpx;
    padding: 40rpx 36rpx;
    margin-bottom: 24rpx;
    box-shadow: 0 10rpx 30rpx rgba(76, 175, 80, 0.3);
    color: #ffffff;
    min-height: 220rpx;
    display: flex;
    align-items: center;
}
.hero-bg-1 {
    position: absolute;
    top: -80rpx;
    right: -60rpx;
    width: 260rpx;
    height: 260rpx;
    background: rgba(255, 255, 255, 0.12);
    border-radius: 50%;
}
.hero-bg-2 {
    position: absolute;
    bottom: -100rpx;
    left: -30rpx;
    width: 200rpx;
    height: 200rpx;
    background: rgba(255, 255, 255, 0.08);
    border-radius: 50%;
}
.hero-content {
    flex: 1;
    position: relative;
    z-index: 2;
}
.hero-greeting {
    font-size: 34rpx;
    font-weight: 700;
    margin-bottom: 12rpx;
    letter-spacing: 1rpx;
}
.hero-slogan {
    font-size: 26rpx;
    opacity: 0.9;
    margin-bottom: 20rpx;
    line-height: 1.5;
}
.hero-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 12rpx;
}
.hero-tag {
    background: rgba(255, 255, 255, 0.22);
    border: 2rpx solid rgba(255, 255, 255, 0.4);
    padding: 8rpx 20rpx;
    border-radius: 30rpx;
    font-size: 22rpx;
    backdrop-filter: blur(10rpx);
    font-weight: 500;
}
.hero-avatar {
    width: 120rpx;
    height: 120rpx;
    background: rgba(255, 255, 255, 0.22);
    border: 4rpx solid rgba(255, 255, 255, 0.5);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 2;
    flex-shrink: 0;
}
.hero-avatar-icon {
    font-size: 60rpx;
}

.stats-card {
    background: #ffffff;
    border-radius: 32rpx;
    padding: 32rpx;
    margin-bottom: 24rpx;
    box-shadow: 0 4rpx 24rpx rgba(15, 23, 42, 0.06);
}
.stats-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 24rpx;
}
.stats-title {
    font-size: 32rpx;
    font-weight: 700;
    color: #1F2937;
    display: flex;
    align-items: center;
}
.stats-title::before {
    content: '';
    display: inline-block;
    width: 6rpx;
    height: 28rpx;
    border-radius: 4rpx;
    background: linear-gradient(180deg, #4CAF50, #66BB6A);
    margin-right: 16rpx;
}
.stats-sub {
    font-size: 24rpx;
    color: #9CA3AF;
}
.stats-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
}
.stat-item {
    width: 33.33%;
    padding: 20rpx 8rpx;
    text-align: center;
    box-sizing: border-box;
    position: relative;
}
.stat-icon-box {
    width: 80rpx;
    height: 80rpx;
    border-radius: 20rpx;
    margin: 0 auto 12rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 40rpx;
}
.stat-bg-green { background: #E8F5E9; }
.stat-bg-orange { background: #FFF3E0; }
.stat-bg-blue { background: #E3F2FD; }
.stat-bg-red { background: #FFEBEE; }
.stat-bg-purple { background: #F3E5F5; }
.stat-bg-cyan { background: #E0F7FA; }
.stat-value {
    font-size: 34rpx;
    font-weight: 700;
    color: #1F2937;
    line-height: 1.3;
    margin-bottom: 4rpx;
}
.stat-label {
    font-size: 22rpx;
    color: #6B7280;
    font-weight: 500;
}

.quick-entry-card {
    background: #ffffff;
    border-radius: 32rpx;
    padding: 32rpx;
    margin-bottom: 24rpx;
    box-shadow: 0 4rpx 24rpx rgba(15, 23, 42, 0.06);
}
.quick-entry-title {
    font-size: 32rpx;
    font-weight: 700;
    color: #1F2937;
    margin-bottom: 28rpx;
    display: flex;
    align-items: center;
}
.quick-entry-title::before {
    content: '';
    display: inline-block;
    width: 6rpx;
    height: 28rpx;
    border-radius: 4rpx;
    background: linear-gradient(180deg, #4CAF50, #66BB6A);
    margin-right: 16rpx;
}
.quick-entry-grid {
    display: flex;
    justify-content: space-between;
}
.quick-entry-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex: 1;
    padding: 12rpx 4rpx;
    transition: transform 0.2s;
}
.quick-entry-item:active { transform: scale(0.95); }
.quick-icon {
    width: 100rpx;
    height: 100rpx;
    border-radius: 24rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 48rpx;
    margin-bottom: 14rpx;
}
.quick-icon-green {
    background: linear-gradient(135deg, #E8F5E9, #C8E6C9);
}
.quick-icon-orange {
    background: linear-gradient(135deg, #FFF3E0, #FFE0B2);
}
.quick-icon-blue {
    background: linear-gradient(135deg, #E3F2FD, #BBDEFB);
}
.quick-icon-purple {
    background: linear-gradient(135deg, #F3E5F5, #E1BEE7);
}
.quick-text {
    font-size: 26rpx;
    color: #374151;
    font-weight: 500;
}

.timeline-card {
    background: #ffffff;
    border-radius: 24rpx;
    padding: 24rpx 28rpx;
    margin-bottom: 16rpx;
    box-shadow: 0 2rpx 12rpx rgba(15, 23, 42, 0.04);
    display: flex;
    align-items: center;
}
.timeline-date-box {
    flex-shrink: 0;
    width: 140rpx;
    padding-right: 20rpx;
}
.timeline-date {
    font-size: 28rpx;
    font-weight: 700;
    color: #1F2937;
    text-align: center;
}
.timeline-divider {
    width: 2rpx;
    height: 60rpx;
    background: #E5E7EB;
    flex-shrink: 0;
    margin-right: 20rpx;
}
.timeline-info {
    flex: 1;
}
.timeline-tags {
    display: flex;
    flex-wrap: wrap;
}