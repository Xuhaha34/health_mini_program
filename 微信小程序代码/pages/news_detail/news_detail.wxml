<!-- pages/news_detail/news_detail.wxml -->
<view class="container" wx:if="{{article}}">
    <image wx:if="{{article.cover_image}}" src="{{article.cover_image}}" mode="aspectFill"
           style="width:100%; height:360rpx; border-radius:16rpx;"/>
    <view class="card mt-20">
        <view class="text-lg text-bold">{{article.title}}</view>
        <view class="flex-between mt-10">
            <text class="text-sm text-gray">{{article.source || ''}} · {{article.author || ''}}</text>
            <text class="text-sm text-gray">{{article.published_at}} · 👁 {{article.view_count}}</text>
        </view>
    </view>
    <view class="card">
        <rich-text nodes="{{article.content}}" style="line-height:1.8;"></rich-text>
    </view>
</view>
<view wx:else class="empty-state">
    <view>加载中...</view>
</view>
