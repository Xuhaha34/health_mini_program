<!-- pages/profile_edit/profile_edit.wxml -->
<view class="container">
    <view class="card">
        <view class="form-item">
            <text class="label">手机号</text>
            <input class="input" placeholder="请输入手机号" value="{{form.phone}}" data-field="phone" bindinput="onInput" />
        </view>
        
        <view class="form-item">
            <text class="label">邮箱</text>
            <input class="input" placeholder="请输入邮箱" value="{{form.email}}" data-field="email" bindinput="onInput" />
        </view>
        
        <view class="form-item">
            <text class="label">性别</text>
            <picker mode="selector" range="{{genderOptions}}" range-key="label" value="{{genderIndex}}" bindchange="onGenderChange">
                <view class="picker">{{form.gender_text || '请选择性别'}}</view>
            </picker>
        </view>
        
        <view class="form-item">
            <text class="label">年龄</text>
            <input class="input" type="number" placeholder="请输入年龄" value="{{form.age}}" data-field="age" bindinput="onInput" />
        </view>
        
        <view class="form-item">
            <text class="label">身高(cm)</text>
            <input class="input" type="digit" placeholder="请输入身高" value="{{form.height}}" data-field="height" bindinput="onInput" />
        </view>
        
        <view class="form-item">
            <text class="label">体重(kg)</text>
            <input class="input" type="digit" placeholder="请输入体重" value="{{form.weight}}" data-field="weight" bindinput="onInput" />
        </view>
    </view>
    
    <button class="btn-primary mt-30" bindtap="saveProfile">保存</button>
    <button class="btn-outline mt-20" bindtap="goBack">取消</button>
</view>
