.login-container {
    min-height: 100vh;
    background: linear-gradient(180deg, #4CAF50 0%, #66BB6A 25%, #F5F7FA 25%, #F5F7FA 100%);
    padding: 80rpx 48rpx 48rpx;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    position: relative;
}

.login-hero {
    text-align: center;
    padding: 40rpx 0 60rpx;
    color: #ffffff;
    position: relative;
    z-index: 2;
}
.hero-circle {
    position: absolute;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.1);
    z-index: -1;
}
.hero-circle-1 { width: 220rpx; height: 220rpx; top: -50rpx; right: -60rpx; }
.hero-circle-2 { width: 140rpx; height: 140rpx; top: 80rpx; left: -30rpx; background: rgba(255, 255, 255, 0.08); }
.hero-circle-3 { width: 80rpx; height: 80rpx; top: 30rpx; right: 150rpx; background: rgba(255, 255, 255, 0.15); }

.login-logo-wrap {
    display: inline-block;
    margin-bottom: 24rpx;
    position: relative;
}
.login-logo {
    width: 140rpx;
    height: 140rpx;
    background: rgba(255, 255, 255, 0.25);
    border: 4rpx solid rgba(255, 255, 255, 0.6);
    border-radius: 36rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 70rpx;
    box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.15);
}
.login-title {
    font-size: 42rpx;
    font-weight: 700;
    letter-spacing: 2rpx;
    margin-bottom: 10rpx;
}
.login-subtitle {
    font-size: 26rpx;
    opacity: 0.9;
}

.login-card {
    background: #ffffff;
    border-radius: 32rpx;
    padding: 48rpx 40rpx;
    box-shadow: 0 8rpx 40rpx rgba(15, 23, 42, 0.08);
    margin-top: 40rpx;
}

.tab-switch {
    display: flex;
    background: #F1F5F9;
    border-radius: 20rpx;
    padding: 8rpx;
    margin-bottom: 40rpx;
}
.tab-item {
    flex: 1;
    text-align: center;
    padding: 24rpx 0;
    font-size: 30rpx;
    color: #6B7280;
    font-weight: 500;
    border-radius: 16rpx;
    transition: all 0.3s;
}
.tab-item.tab-active {
    background: #ffffff;
    color: #4CAF50;
    font-weight: 700;
    box-shadow: 0 2rpx 8rpx rgba(15, 23, 42, 0.08);
}

.form-wrap {
    margin-bottom: 36rpx;
}
.field-box {
    display: flex;
    align-items: center;
    background: #F8FAFC;
    border: 2rpx solid #E2E8F0;
    border-radius: 20rpx;
    padding: 0 24rpx;
    height: 100rpx;
    margin-bottom: 20rpx;
    transition: all 0.2s;
}
.field-box:focus-within {
    background: #ffffff;
    border-color: #4CAF50;
    box-shadow: 0 0 0 6rpx rgba(76, 175, 80, 0.1);
}
.field-icon {
    font-size: 32rpx;
    margin-right: 16rpx;
    opacity: 0.7;
    flex-shrink: 0;
}
.field-input {
    flex: 1;
    height: 100rpx;
    font-size: 30rpx;
    color: #1F2937;
}

.btn-submit {
    width: 100%;
    margin-top: 12rpx;
    padding: 28rpx 0;
    font-size: 32rpx;
    font-weight: 700;
    letter-spacing: 4rpx;
}

.switch-hint {
    text-align: center;
    margin-top: 32rpx;
    font-size: 26rpx;
    color: #6B7280;
    padding: 8rpx 0;
}
.switch-hint:active { color: #4CAF50; }

.login-footer {
    margin-top: auto;
    padding-top: 60rpx;
    text-align: center;
}
.footer-text {
    font-size: 22rpx;
    color: #9CA3AF;
    letter-spacing: 1rpx;
}