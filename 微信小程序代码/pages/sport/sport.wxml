<!-- pages/sport/sport.wxml -->
<view class="container">

    <!-- 顶部操作栏 -->
    <view class="action-bar">
        <view class="action-title">
            <text class="action-title-text">运动记录</text>
            <text class="action-title-sub">共 {{records.length}} 条记录</text>
        </view>
        <button class="btn-add" bindtap="showAddForm">+ 记录</button>
    </view>

    <!-- 记录列表 -->
    <view wx:for="{{records}}" wx:key="id" class="record-item">
        <view class="record-item-header">
            <view style="display:flex;align-items:center;flex:1;">
                <text class="record-item-title">{{item.sport_type_display}}</text>
            </view>
            <text class="record-item-delete" data-id="{{item.id}}" bindtap="deleteRecord">删除</text>
        </view>
        <view class="record-item-data">
            <text class="data-tag">时长<strong>{{item.duration}} 分钟</strong></text>
            <text class="data-tag data-tag-green" wx:if="{{item.calories}}">消耗<strong>{{item.calories}} 千卡</strong></text>
            <text class="data-tag" wx:if="{{item.distance}}">距离<strong>{{item.distance}} km</strong></text>
            <text class="data-tag" wx:if="{{item.heart_rate}}">心率<strong>{{item.heart_rate}}</strong></text>
        </view>
        <view class="record-item-footer">📅 {{item.sport_date}}</view>
    </view>

    <view wx:if="{{records.length === 0}}" class="empty-state">
        <view class="empty-icon">🏃</view>
        <view class="empty-title">暂无运动记录</view>
        <view class="empty-desc">动起来，让每一次锻炼都有意义</view>
    </view>

    <!-- 弹窗 -->
    <view class="modal" wx:if="{{showForm}}" catchtap="hideForm">
        <view class="modal-content" catchtap="">
            <view class="modal-header">
                <view class="modal-title">记录运动</view>
                <text class="modal-close" bindtap="hideForm">✕</text>
            </view>

            <view class="modal-form">
                <view class="form-field">
                    <text class="form-label">📅 日期</text>
                    <picker mode="date" value="{{form.sport_date}}" bindchange="onDateChange">
                        <view class="picker-box">{{form.sport_date}} <text class="picker-arrow">›</text></view>
                    </picker>
                </view>
                <view class="form-field">
                    <text class="form-label">🏃 运动类型</text>
                    <view class="type-selector">
                        <text class="type-tag {{form.sport_type === item.value ? 'type-tag-active' : ''}}"
                              wx:for="{{sportTypes}}" wx:key="value"
                              data-type="{{item.value}}" bindtap="selectSportType">{{item.label}}</text>
                    </view>
                </view>
                <view class="form-field">
                    <text class="form-label">⏱️ 时长(分钟)</text>
                    <input type="number" placeholder="运动了多少分钟" value="{{form.duration}}" data-field="duration" bindinput="onFormInput" class="form-input"/>
                </view>
                <view class="form-field">
                    <text class="form-label">🔥 消耗(千卡)</text>
                    <input type="number" placeholder="约消耗多少千卡" value="{{form.calories}}" data-field="calories" bindinput="onFormInput" class="form-input"/>
                </view>
                <view class="form-field">
                    <text class="form-label">📏 距离(km)</text>
                    <input type="digit" placeholder="选填" value="{{form.distance}}" data-field="distance" bindinput="onFormInput" class="form-input"/>
                </view>
                <view class="form-field">
                    <text class="form-label">❤️ 心率</text>
                    <input type="number" placeholder="选填" value="{{form.heart_rate}}" data-field="heart_rate" bindinput="onFormInput" class="form-input"/>
                </view>
                <view class="form-field">
                    <text class="form-label">💭 备注</text>
                    <input placeholder="选填，记录运动感受..." value="{{form.remark}}" data-field="remark" bindinput="onFormInput" class="form-input"/>
                </view>
            </view>

            <button class="btn-primary btn-modal" bindtap="saveRecord">保 存</button>
        </view>
    </view>
</view>