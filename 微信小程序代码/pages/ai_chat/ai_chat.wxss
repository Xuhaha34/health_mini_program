.chat-container {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    background: #F5F7FA;
}

.chat-header {
    background: #ffffff;
    padding: 24rpx 20rpx;
    display: flex;
    align-items: center;
    box-shadow: 0 2rpx 12rpx rgba(15, 23, 42, 0.04);
    z-index: 10;
    position: sticky;
    top: 0;
}
.header-left, .header-right {
    flex-shrink: 0;
}
.header-icon-btn {
    width: 72rpx;
    height: 72rpx;
    border-radius: 18rpx;
    background: #F1F5F9;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 36rpx;
    color: #475569;
}
.header-icon-btn:active {
    background: #E2E8F0;
}
.header-center {
    flex: 1;
    text-align: center;
    padding: 0 16rpx;
}
.chat-header-title {
    font-size: 32rpx;
    font-weight: 700;
    color: #1F2937;
    margin-bottom: 4rpx;
}
.chat-header-status {
    display: inline-flex;
    align-items: center;
    background: #E8F5E9;
    padding: 6rpx 16rpx;
    border-radius: 20rpx;
}
.status-dot {
    width: 12rpx;
    height: 12rpx;
    border-radius: 50%;
    background: #4CAF50;
    margin-right: 10rpx;
    animation: pulse 2s infinite;
}
@keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
}
.status-text {
    font-size: 22rpx;
    color: #2E7D32;
    font-weight: 500;
}

.sidebar {
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
    z-index: 100;
    display: flex;
}
.sidebar-mask {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background: rgba(15, 23, 42, 0.4);
}
.sidebar-content {
    position: relative;
    background: #ffffff;
    width: 70%;
    height: 100%;
    padding: 40rpx 28rpx;
    box-sizing: border-box;
    border-radius: 0 32rpx 32rpx 0;
    box-shadow: 4rpx 0 20rpx rgba(0, 0, 0, 0.1);
    animation: slideFromLeft 0.3s ease;
}
@keyframes slideFromLeft {
    from { transform: translateX(-100%); }
    to { transform: translateX(0); }
}
.sidebar-header {
    font-size: 32rpx;
    font-weight: 700;
    color: #1F2937;
    margin-bottom: 24rpx;
    padding-bottom: 20rpx;
    border-bottom: 2rpx solid #F1F5F9;
}
.session-list {
    flex: 1;
}
.session-item {
    background: #F8FAFC;
    border-radius: 16rpx;
    padding: 20rpx 24rpx;
    margin-bottom: 16rpx;
    display: flex;
    justify-content: space-between;
    align-items: center;
}
.session-item-title {
    font-size: 26rpx;
    color: #374151;
    font-weight: 500;
    flex: 1;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}
.session-item-delete {
    font-size: 22rpx;
    color: #EF4444;
    margin-left: 16rpx;
    background: #FFEBEE;
    padding: 6rpx 16rpx;
    border-radius: 20rpx;
    flex-shrink: 0;
}
.sidebar-empty {
    text-align: center;
    color: #9CA3AF;
    font-size: 26rpx;
    padding: 80rpx 20rpx;
}

.messages-container {
    flex: 1;
    padding: 32rpx 24rpx;
    box-sizing: border-box;
}

.chat-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 80rpx 20rpx 40rpx;
}
.chat-empty-icon {
    font-size: 120rpx;
    margin-bottom: 24rpx;
    background: #ffffff;
    width: 180rpx;
    height: 180rpx;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.08);
}
.chat-empty-title {
    font-size: 34rpx;
    font-weight: 700;
    color: #1F2937;
    margin-bottom: 10rpx;
}
.chat-empty-desc {
    font-size: 26rpx;
    color: #6B7280;
    margin-bottom: 40rpx;
}
.chat-empty-suggest {
    width: 100%;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
}
.suggest-item {
    background: #ffffff;
    color: #374151;
    padding: 18rpx 28rpx;
    border-radius: 30rpx;
    font-size: 26rpx;
    margin: 0 12rpx 16rpx;
    font-weight: 500;
    box-shadow: 0 2rpx 12rpx rgba(15, 23, 42, 0.04);
    transition: all 0.2s;
}
.suggest-item:active {
    background: #E8F5E9;
    color: #2E7D32;
    transform: scale(0.98);
}

.msg-wrapper {
    margin-bottom: 24rpx;
}
.msg {
    display: flex;
    align-items: flex-start;
    max-width: 85%;
}
.msg-left {
    align-items: flex-start;
}
.msg-right {
    margin-left: auto;
    flex-direction: row-reverse;
}
.msg-avatar {
    width: 72rpx;
    height: 72rpx;
    border-radius: 18rpx;
    background: #E8F5E9;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 36rpx;
    margin-right: 16rpx;
    flex-shrink: 0;
}
.msg-avatar-user {
    background: linear-gradient(135deg, #4CAF50, #66BB6A);
    margin-right: 0;
    margin-left: 16rpx;
}
.msg-bubble {
    padding: 20rpx 28rpx;
    border-radius: 24rpx;
    font-size: 28rpx;
    line-height: 1.6;
    word-break: break-word;
    box-shadow: 0 2rpx 8rpx rgba(15, 23, 42, 0.04);
}
.bubble-left {
    background: #ffffff;
    color: #1F2937;
    border-top-left-radius: 8rpx;
}
.bubble-right {
    background: linear-gradient(135deg, #4CAF50, #66BB6A);
    color: #ffffff;
    border-top-right-radius: 8rpx;
}
.typing-bubble {
    padding: 24rpx 28rpx;
    display: flex;
    align-items: center;
}
.typing-dot {
    font-size: 28rpx;
    opacity: 0.5;
    animation: typingBounce 1.4s infinite;
}
.typing-dot-2 {
    animation-delay: 0.2s;
    margin-left: 6rpx;
}
.typing-dot-3 {
    animation-delay: 0.4s;
    margin-left: 6rpx;
}
@keyframes typingBounce {
    0%, 60%, 100% { transform: translateY(0); opacity: 0.3; }
    30% { transform: translateY(-8rpx); opacity: 1; }
}
.msg-meta {
    padding-left: 88rpx;
    margin-top: 8rpx;
}
.msg-meta-text {
    font-size: 22rpx;
    color: #9CA3AF;
}

.input-bar {
    background: #ffffff;
    padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
    display: flex;
    align-items: center;
    box-shadow: 0 -2rpx 12rpx rgba(15, 23, 42, 0.04);
}
.chat-input {
    flex: 1;
    background: #F8FAFC;
    border: 2rpx solid #E2E8F0;
    border-radius: 40rpx;
    padding: 20rpx 28rpx;
    font-size: 28rpx;
    height: auto;
    box-sizing: border-box;
    margin-right: 16rpx;
    color: #1F2937;
}
.chat-input:focus {
    border-color: #4CAF50;
    background: #ffffff;
}
.btn-send {
    background: linear-gradient(135deg, #4CAF50, #66BB6A);
    color: #ffffff;
    border: none;
    border-radius: 40rpx;
    padding: 20rpx 36rpx;
    font-size: 28rpx;
    font-weight: 600;
    box-shadow: 0 4rpx 16rpx rgba(76, 175, 80, 0.25);
    flex-shrink: 0;
    line-height: 1.4;
}
.btn-send::after { border: none; }
.btn-send-disabled {
    background: #CBD5E1;
    color: #64748B;
    box-shadow: none;
}
.btn-send:active:not(.btn-send-disabled) {
    transform: scale(0.98);
}